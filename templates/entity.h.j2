{#
  实体类头文件模板 (Entity_<Class>.h)。
  上下文:
    class_name -- 表名的 PascalCase, 如 "Player"
    table_name -- 表名, 如 "player"
    fields     -- 字段列表, 每项: name, cpp_type, default_value, comment, is_json
    python_version -- 生成时使用的 Python 版本
    script_version -- 生成器版本
  渲染选项: trim_blocks=True, lstrip_blocks=True, keep_trailing_newline=True
#}
#pragma once

/**
 * Entity mapping the columns of the `{{ table_name }}` table.
 * This file is generated by Python script. Do not edit!!!
 * Python version: v{{ python_version }}
 * Script version: v{{ script_version }}
 */

#include <actor/runtime/database/Entity.h>
{% if fields | selectattr('is_json') | list %}

#include <nlohmann/json.hpp>
{% endif %}

using uranus::actor::runtime::database::Entity;

class Entity_{{ class_name }} final : public Entity {
public:
{% for f in fields %}
    {{ f.cpp_type }} {{ f.name }}{{ f.default_value }};{{ (' // ' ~ f.comment) if f.comment }}
{% endfor %}
};
