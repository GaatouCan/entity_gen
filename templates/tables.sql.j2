{#
  MySQL 建表 SQL 模板 (<meta 文件名>.sql)，一个文件包含该 meta 中的所有表。
  上下文:
    tables -- 表列表, 每项: table_name, comment, fields
              fields 每项: name, sql_type, not_null, default_value, is_key, comment
  渲染选项: trim_blocks=True, lstrip_blocks=True, keep_trailing_newline=True
#}
-- This file is generated by Python script. Do not edit!!!

{% for t in tables %}
{% set key_fields = t.fields | selectattr('is_key') | list %}
CREATE TABLE `{{ t.table_name }}`
(
{% for f in t.fields %}
	`{{ f.name }}`	{{ f.sql_type }}{{ ' NOT NULL' if f.not_null }}{{ f.default_value }}{{ (" COMMENT '" ~ f.comment ~ "'") if f.comment }}{{ ',' if not loop.last or key_fields }}
{% endfor %}
{% if key_fields %}
	PRIMARY KEY ({% for f in key_fields %}`{{ f.name }}`{{ ', ' if not loop.last }}{% endfor %})
{% endif %}
) ENGINE = InnoDB DEFAULT CHARSET = utf8mb4 COMMENT '{{ t.comment }}';
{% if not loop.last %}

{% endif %}
{% endfor %}
